{
  "name": "cexp-hub-sdk",
  "version": "0.1.0",
  "description": "CExP Hub browser SDK facade.",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "jsdom": "29.0.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./iife": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.global.js"
    }
  }
}
