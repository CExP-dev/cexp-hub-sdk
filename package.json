{
  "name": "cexp-hub-sdk",
  "version": "0.3.0",
  "description": "CExP Hub browser SDK facade.",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "jsdom": "29.0.1",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./iife": {
      "types": "./dist/index.d.ts",
      "default": "./dist/browser.global.js"
    }
  }
}
